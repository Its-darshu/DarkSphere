// DarkSphere - Twitter-like Social Platform
// Prisma Schema with PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== ENUMS =====
enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

// ===== USER MODEL =====
model User {
  id                String     @id @default(cuid())
  username          String     @unique
  passwordHash      String
  bio               String?
  avatarUrl         String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  isBanned          Boolean    @default(false)
  role              AdminRole?

  // Relations
  posts             Post[]
  comments          Comment[]
  likes             Like[]
  retweets          Retweet[]
  reports           Report[]
  adminLogs         AdminLog[]

  // Follow relations
  followers         Follow[]   @relation("following")
  following         Follow[]   @relation("follower")

  @@index([username])
  @@index([createdAt])
  @@map("users")
}

// ===== POST MODEL =====
model Post {
  id                String     @id @default(cuid())
  content           String     @db.Text
  imageUrl          String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Author
  author            User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId          String

  // Relations
  comments          Comment[]
  likes             Like[]
  retweets          Retweet[]
  reports           Report[]

  @@index([authorId])
  @@index([createdAt])
  @@map("posts")
}

// ===== COMMENT MODEL (Nested Replies) =====
model Comment {
  id                String     @id @default(cuid())
  content           String     @db.Text
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Post relation
  post              Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId            String

  // Author
  author            User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId          String

  // Nested replies (optional parent comment)
  parentComment     Comment?   @relation("replies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  parentCommentId   String?
  replies           Comment[]  @relation("replies")

  // Likes on comments
  likes             Like[]

  @@index([postId])
  @@index([authorId])
  @@index([parentCommentId])
  @@map("comments")
}

// ===== LIKE MODEL =====
model Like {
  id                String     @id @default(cuid())
  createdAt         DateTime   @default(now())

  // User
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String

  // Can like post OR comment (not both)
  post              Post?      @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId            String?

  comment           Comment?   @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId         String?

  // Ensure one like per user per post/comment
  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([postId])
  @@index([commentId])
  @@map("likes")
}

// ===== RETWEET MODEL =====
model Retweet {
  id                String     @id @default(cuid())
  createdAt         DateTime   @default(now())

  // User who retweeted
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String

  // Original post
  post              Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId            String

  // Ensure one retweet per user per post
  @@unique([userId, postId])
  @@index([postId])
  @@map("retweets")
}

// ===== FOLLOW MODEL =====
model Follow {
  id                String     @id @default(cuid())
  createdAt         DateTime   @default(now())

  // User following
  follower          User       @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followerId        String

  // User being followed
  following         User       @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  followingId       String

  // Ensure no duplicate follows
  @@unique([followerId, followingId])
  @@index([followingId])
  @@map("follows")
}

// ===== REPORT MODEL =====
model Report {
  id                String     @id @default(cuid())
  reason            String     // "offensive", "spam", "harassment", etc.
  description       String?    @db.Text
  status            String     @default("pending") // "pending", "resolved", "dismissed"
  createdAt         DateTime   @default(now())
  resolvedAt        DateTime?

  // Reported post
  post              Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId            String

  // Reporter
  reporter          User       @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reporterId        String

  @@index([postId])
  @@index([reporterId])
  @@index([status])
  @@map("reports")
}

// ===== ADMIN LOG MODEL (Audit Trail) =====
model AdminLog {
  id                String     @id @default(cuid())
  action            String     // "ban_user", "unban_user", "delete_post", "assign_role", "resolve_report"
  targetUserId      String?    // User affected
  targetPostId      String?    // Post affected
  details           String?    @db.Text // Additional details
  createdAt         DateTime   @default(now())

  // Admin who performed action
  admin             User       @relation(fields: [adminId], references: [id], onDelete: SetNull)
  adminId           String

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@map("admin_logs")
}
